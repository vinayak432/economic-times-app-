pipeline {
    agent any

    environment {
        APP_NAME = "economic-times-app"
        DOCKER_IMAGE = "vinayak432/economic-times-app"
        IMAGE_TAG = "${BUILD_NUMBER}"

        CHART_DIR = "helm/economic-times-app"
        CHART_NAME = "economic-times-app"

        JFROG_BASE_URL = "https://trial1ttau5.jfrog.io/"
        JFROG_HELM_REPO = "helm-economic-times-app"
        JFROG_HELM_URL = "${JFROG_BASE_URL}/artifactory/${JFROG_HELM_REPO}"

        KUBE_NAMESPACE = "default"
        RELEASE_NAME = "economic-times-app"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vinayak432/economic-times-app-.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -t ${DOCKER_IMAGE}:${IMAGE_TAG} .
                    docker tag ${DOCKER_IMAGE}:${IMAGE_TAG} ${DOCKER_IMAGE}:latest
                """
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh """
                        echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                        docker push ${DOCKER_IMAGE}:${IMAGE_TAG}
                        docker push ${DOCKER_IMAGE}:latest
                        
                    """
                }
            }
        }

        stage('Update values.yaml image tag') {
            steps {
                sh """
                    sed -i 's|repository:.*|  repository: ${DOCKER_IMAGE}|' ${CHART_DIR}/values.yaml
                    sed -i 's|tag:.*|  tag: "${IMAGE_TAG}"|' ${CHART_DIR}/values.yaml
                """
            }
        }

        stage('Update Chart.yaml version') {
            steps {
                sh """
                    sed -i 's|^version:.*|version: 0.1.${BUILD_NUMBER}|' ${CHART_DIR}/Chart.yaml
                    sed -i 's|^appVersion:.*|appVersion: "${IMAGE_TAG}"|' ${CHART_DIR}/Chart.yaml
                """
            }
        }

        stage('Lint Helm Chart') {
            steps {
                sh "helm lint ${CHART_DIR}"
            }
        }

        stage('Package Helm Chart') {
            steps {
                sh """
                    mkdir -p packaged
                    helm package ${CHART_DIR} -d packaged
                    ls -lh packaged
                """
            }
        }

        stage('Upload Chart to JFrog') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'jfrog-creds', usernameVariable: 'JFROG_USER', passwordVariable: 'JFROG_PASS')]) {
                    sh """
                        CHART_PACKAGE=\$(ls packaged/${CHART_NAME}-*.tgz | head -n 1)
                        echo "Uploading \$CHART_PACKAGE to ${JFROG_HELM_URL}"
                        curl -u "${JFROG_USER}:${JFROG_PASS}" -T \$CHART_PACKAGE ${JFROG_HELM_URL}/
                    """
                }
            }
        }

        stage('Pull Chart from JFrog') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'jfrog-creds', usernameVariable: 'JFROG_USER', passwordVariable: 'JFROG_PASS')]) {
                    sh """
                        helm repo remove jfrog-helm || true
                        helm repo add jfrog-helm ${JFROG_HELM_URL} --username ${JFROG_USER} --password ${JFROG_PASS}
                        helm repo update
                        helm pull jfrog-helm/${CHART_NAME}
                        ls -lh *.tgz
                    """
                }
            }
        }

        stage('Deploy from JFrog Helm Repo') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'jfrog-creds', usernameVariable: 'JFROG_USER', passwordVariable: 'JFROG_PASS'),
                    file(credentialsId: 'kubeconfig-file', variable: 'KUBECONFIG_FILE')
                ]) {
                    sh """
                        export KUBECONFIG=${KUBECONFIG_FILE}

                        helm repo remove jfrog-helm || true
                        helm repo add jfrog-helm ${JFROG_HELM_URL} --username ${JFROG_USER} --password ${JFROG_PASS}
                        helm repo update

                        helm upgrade --install ${RELEASE_NAME} jfrog-helm/${CHART_NAME} \
                          --namespace ${KUBE_NAMESPACE} \
                          --create-namespace \
                          --set name=${APP_NAME} \
                          --set namespace=${KUBE_NAMESPACE} \
                          --set image.repository=${DOCKER_IMAGE} \
                          --set image.tag=${IMAGE_TAG}

                        kubectl get pods -n ${KUBE_NAMESPACE}
                        kubectl get svc -n ${KUBE_NAMESPACE}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "SUCCESS: Docker image pushed, Helm chart uploaded to JFrog, pulled and deployed successfully."
        }
        failure {
            echo "FAILED: Check Jenkins logs."
        }
        always {
            cleanWs()
        }
    }
}
